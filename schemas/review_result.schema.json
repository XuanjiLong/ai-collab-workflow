{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.com/schemas/review_result.schema.json",
  "type": "object",
  "required": [
    "task_id",
    "review_id",
    "verdict",
    "summary",
    "quality_score",
    "weight_profile_used",
    "weighted_score_breakdown",
    "risk_level",
    "scorecard",
    "block_issues",
    "advisory_issues",
    "suggestions",
    "recommended_decision_mode",
    "alignment"
  ],
  "additionalProperties": false,
  "properties": {
    "task_id": {"type": "string"},
    "review_id": {"type": "string"},
    "verdict": {
      "type": "string",
      "enum": ["pass", "pass_with_suggestions", "block"]
    },
    "summary": {"type": "string"},
    "quality_score": {"type": "integer", "minimum": 0, "maximum": 100},
    "weight_profile_used": {
      "type": "string",
      "enum": ["new_feature", "refactor", "bugfix", "balanced"]
    },
    "weighted_score_breakdown": {
      "type": "object",
      "required": [
        "goal_coverage",
        "constraint_compliance",
        "correctness",
        "regression_risk",
        "test_confidence"
      ],
      "additionalProperties": false,
      "properties": {
        "goal_coverage": {"type": "number", "minimum": 0},
        "constraint_compliance": {"type": "number", "minimum": 0},
        "correctness": {"type": "number", "minimum": 0},
        "regression_risk": {"type": "number", "minimum": 0},
        "test_confidence": {"type": "number", "minimum": 0}
      }
    },
    "risk_level": {"type": "string", "enum": ["low", "medium", "high"]},
    "scorecard": {
      "type": "object",
      "required": [
        "goal_coverage",
        "constraint_compliance",
        "correctness",
        "regression_risk",
        "test_confidence"
      ],
      "additionalProperties": false,
      "properties": {
        "goal_coverage": {"type": "integer", "minimum": 0, "maximum": 2},
        "constraint_compliance": {"type": "integer", "minimum": 0, "maximum": 2},
        "correctness": {"type": "integer", "minimum": 0, "maximum": 2},
        "regression_risk": {"type": "integer", "minimum": 0, "maximum": 2},
        "test_confidence": {"type": "integer", "minimum": 0, "maximum": 2}
      }
    },
    "block_issues": {
      "type": "array",
      "items": {"$ref": "#/$defs/block_issue"}
    },
    "advisory_issues": {
      "type": "array",
      "items": {"$ref": "#/$defs/advisory_issue"}
    },
    "suggestions": {
      "type": "array",
      "items": {"type": "string"}
    },
    "recommended_decision_mode": {
      "type": "string",
      "enum": ["auto_approve", "human_optional", "human_required"]
    },
    "alignment": {
      "type": "object",
      "required": ["coder_self_review_delta", "definition_mismatch"],
      "additionalProperties": false,
      "properties": {
        "coder_self_review_delta": {
          "type": "object",
          "required": ["quality_score_diff", "correctness_diff"],
          "additionalProperties": false,
          "properties": {
            "quality_score_diff": {"type": "integer"},
            "correctness_diff": {"type": "integer"}
          }
        },
        "definition_mismatch": {
          "type": "array",
          "items": {"type": "string"}
        }
      }
    }
  },
  "$defs": {
    "block_issue": {
      "type": "object",
      "required": ["id", "title", "severity", "file", "line", "expected"],
      "additionalProperties": false,
      "properties": {
        "id": {"type": "string"},
        "title": {"type": "string"},
        "severity": {"type": "string", "enum": ["low", "medium", "high"]},
        "file": {"type": "string"},
        "line": {"type": "integer", "minimum": 1},
        "expected": {"type": "string"}
      }
    },
    "advisory_issue": {
      "type": "object",
      "required": ["id", "title", "severity", "file", "line", "expected"],
      "additionalProperties": false,
      "properties": {
        "id": {"type": "string"},
        "title": {"type": "string"},
        "severity": {"type": "string", "enum": ["low", "medium"]},
        "file": {"type": "string"},
        "line": {"type": "integer", "minimum": 1},
        "expected": {"type": "string"}
      }
    }
  }
}
