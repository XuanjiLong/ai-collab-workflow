{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.com/schemas/decision_record.schema.json",
  "type": "object",
  "required": [
    "task_id",
    "round",
    "action",
    "decision_mode",
    "decision_source",
    "comment",
    "created_at"
  ],
  "additionalProperties": false,
  "properties": {
    "task_id": {"type": "string"},
    "round": {"type": "integer", "minimum": 1},
    "action": {"type": "string", "enum": ["auto_approve", "approve", "reject"]},
    "decision_mode": {
      "type": "string",
      "enum": ["auto_approve", "human_optional", "human_required"]
    },
    "decision_source": {"type": "string", "enum": ["system", "human"]},
    "comment": {"type": "string"},
    "created_at": {"type": "string", "format": "date-time"}
  }
}
