{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.com/schemas/task_contract.schema.json",
  "type": "object",
  "required": [
    "task_id",
    "type",
    "work_type",
    "goal",
    "context",
    "constraints",
    "review_rubric",
    "approval_policy",
    "retry_policy",
    "output_schema",
    "done_criteria",
    "owner_agent",
    "status",
    "retry_count"
  ],
  "additionalProperties": false,
  "properties": {
    "task_id": {"type": "string"},
    "type": {"type": "string"},
    "work_type": {"type": "string", "enum": ["new_feature", "refactor", "bugfix", "other"]},
    "goal": {"type": "string", "minLength": 1},
    "context": {"type": "object"},
    "constraints": {
      "type": "array",
      "items": {"type": "string"}
    },
    "review_rubric": {
      "type": "object",
      "required": [
        "version",
        "dimensions",
        "weight_profiles",
        "weight_profile_by_work_type",
        "active_weight_profile",
        "scoring_scale",
        "block_threshold",
        "pass_threshold",
        "correctness_definition"
      ],
      "additionalProperties": false,
      "properties": {
        "version": {"type": "string"},
        "dimensions": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": [
              "goal_coverage",
              "constraint_compliance",
              "correctness",
              "regression_risk",
              "test_confidence"
            ]
          },
          "minItems": 5
        },
        "weight_profiles": {
          "type": "object",
          "minProperties": 1,
          "additionalProperties": {"$ref": "#/$defs/weight_profile"}
        },
        "weight_profile_by_work_type": {
          "type": "object",
          "required": ["new_feature", "refactor", "bugfix", "other"],
          "additionalProperties": false,
          "properties": {
            "new_feature": {"type": "string"},
            "refactor": {"type": "string"},
            "bugfix": {"type": "string"},
            "other": {"type": "string"}
          }
        },
        "active_weight_profile": {"type": "string"},
        "scoring_scale": {"type": "string"},
        "block_threshold": {"type": "integer", "minimum": 0, "maximum": 100},
        "pass_threshold": {"type": "integer", "minimum": 0, "maximum": 100},
        "correctness_definition": {
          "type": "array",
          "items": {"type": "string"},
          "minItems": 1
        }
      }
    },
    "approval_policy": {
      "type": "object",
      "required": [
        "mode",
        "auto_approve_min_quality_score",
        "human_optional_sla_seconds",
        "human_required_max_wait_seconds"
      ],
      "additionalProperties": false,
      "properties": {
        "mode": {"type": "string"},
        "auto_approve_min_quality_score": {"type": "integer", "minimum": 0, "maximum": 100},
        "human_optional_sla_seconds": {"type": "integer", "minimum": 1},
        "human_required_max_wait_seconds": {"type": "integer", "minimum": 1}
      }
    },
    "retry_policy": {
      "type": "object",
      "required": [
        "strategy",
        "complexity_level",
        "complexity_score",
        "max_rework_rounds",
        "override_reason",
        "escalation_owner",
        "allowed_escalation_actions"
      ],
      "additionalProperties": false,
      "properties": {
        "strategy": {"type": "string"},
        "complexity_level": {"type": "string", "enum": ["low", "medium", "high", "critical"]},
        "complexity_score": {"type": "integer", "minimum": 1},
        "max_rework_rounds": {"type": "integer", "minimum": 1},
        "override_reason": {"type": ["string", "null"]},
        "escalation_owner": {"type": "string"},
        "allowed_escalation_actions": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": ["split_task", "adjust_constraints", "change_owner", "extend_retry_budget"]
          }
        }
      }
    },
    "output_schema": {
      "type": "object",
      "required": ["required"],
      "additionalProperties": true,
      "properties": {
        "required": {
          "type": "array",
          "items": {"type": "string"}
        }
      }
    },
    "done_criteria": {
      "type": "array",
      "items": {"type": "string"}
    },
    "owner_agent": {"type": "string"},
    "status": {"type": "string"},
    "deadline": {"type": ["string", "null"]},
    "retry_count": {"type": "integer", "minimum": 0},
    "rework": {
      "type": ["object", "null"],
      "required": [
        "from_round",
        "previous_review_result",
        "previous_decision_record",
        "rework_constraints",
        "artifact_refs"
      ],
      "additionalProperties": false,
      "properties": {
        "from_round": {"type": "integer", "minimum": 1},
        "previous_review_result": {
          "type": "object",
          "required": ["review_id", "verdict", "block_issues"],
          "additionalProperties": true,
          "properties": {
            "review_id": {"type": "string"},
            "verdict": {"type": "string"},
            "block_issues": {"type": "array"}
          }
        },
        "previous_decision_record": {
          "type": "object",
          "required": ["action", "decision_mode", "decision_source", "comment"],
          "additionalProperties": true,
          "properties": {
            "action": {"type": "string"},
            "decision_mode": {"type": "string"},
            "decision_source": {"type": "string"},
            "comment": {"type": "string"}
          }
        },
        "rework_constraints": {
          "type": "array",
          "items": {"type": "string"}
        },
        "artifact_refs": {"type": "object"}
      }
    }
  },
  "$defs": {
    "weight_profile": {
      "type": "object",
      "required": [
        "goal_coverage",
        "constraint_compliance",
        "correctness",
        "regression_risk",
        "test_confidence"
      ],
      "additionalProperties": false,
      "properties": {
        "goal_coverage": {"type": "number", "minimum": 0, "maximum": 1},
        "constraint_compliance": {"type": "number", "minimum": 0, "maximum": 1},
        "correctness": {"type": "number", "minimum": 0, "maximum": 1},
        "regression_risk": {"type": "number", "minimum": 0, "maximum": 1},
        "test_confidence": {"type": "number", "minimum": 0, "maximum": 1}
      }
    }
  }
}
